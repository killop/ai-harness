{
  "mappings": [
    {
      "name": "design_docs",
      "source": "DesignDoc",
      "target": "game_design/generated/DesignDoc",
      "include": ["*.md"],
      "recursive": true,
      "exclude": ["images/*", "images/**/*"]
    },
    {
      "name": "architecture_docs",
      "source": "docs/architecture",
      "target": "game_shared/generated/docs-architecture",
      "include": ["*.md"],
      "recursive": true,
      "exclude": []
    },
    {
      "name": "aidoc_top_level",
      "source": "AiDoc",
      "target": "game_shared/generated/AiDoc",
      "include": ["*.md"],
      "recursive": false,
      "exclude": ["CodeReview/*", "CodeReview/**/*"]
    }
  ]
}
